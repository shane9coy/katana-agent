# ============================================================
# X-to-Threads Stream Listener — Environment Variables
# Copy to .env and fill in your credentials.
# ============================================================

# === X API v2 (pay-per-use) ===
# https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=
X_USERNAME=your_handle_no_at_sign

# === Meta Threads (Instagram login) ===
# WARNING: Test with a dummy account first!
THREADS_USERNAME=
THREADS_PASSWORD=

# === Optional ===
# THREADS_PROXY_HTTP=
# THREADS_PROXY_HTTPS=
# THREADS_TIMEOUT=10
